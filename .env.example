# ═══════════════════════════════════════════════════════════════════════════════
# EXTERIOR EXPERTS CRM — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────────────────────────

# Database (PostgreSQL via Docker or remote)
# Local: Run `docker compose up -d` first, then use this URL
# Remote: Replace with your PostgreSQL connection string
DATABASE_URL=postgresql://crm_user:crm_password@localhost:5432/exterior_experts_crm

# Auth: JWT signing key (used for session cookies)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-64-character-hex-string

# Auth: Google OAuth 2.0 Credentials
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add authorized redirect URIs (see below)
GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Auth: Owner/admin email (user with this email becomes admin on first login)
OWNER_OPEN_ID=admin@exteriorexperts.co

# ─── OPTIONAL: SMS & COMMUNICATIONS ────────────────────────────────────────────

# Twilio (SMS inbox, outbound SMS)
# Get from https://console.twilio.com
# Leave blank to disable SMS features (app still works)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Anthropic (AI receptionist for auto-replies)
# Get from https://console.anthropic.com
# Leave blank to disable AI auto-reply (app still works)
ANTHROPIC_API_KEY=

# ─── OPTIONAL: FILE STORAGE ────────────────────────────────────────────────────

# AWS S3 for file uploads (quotes, invoices, etc.)
# Leave blank to use local /public/uploads fallback
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ─── INTERNAL (leave blank for local dev) ──────────────────────────────────────
# Used only when proxying requests through a Forge server
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
